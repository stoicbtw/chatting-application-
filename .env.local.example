# ─── Supabase ─────────────────────────────────────────────
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY, never expose to the browser.
# Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# ─── KLIPY (GIFs) ─────────────────────────────────────────
# Get a key from the Partner Panel: https://klipy.com/developers
# (Tenor shut down its public GIF API, so we use KLIPY.)
KLIPY_API_KEY=your-klipy-api-key

# ─── Session ──────────────────────────────────────────────
# Any long random string. Used to sign login cookies + hash passcodes.
# Generate one: run  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string
